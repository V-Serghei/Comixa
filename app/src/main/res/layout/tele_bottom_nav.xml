<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/teleBottomNav"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:background="@android:color/white"
    android:paddingHorizontal="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:elevation="8dp">

    <LinearLayout
        android:id="@+id/navTeleHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_tele_nav_home"
            app:tint="@color/tele_green" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Home"
            android:textSize="12sp"
            android:textColor="@color/tele_green" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navTeleNotification"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_tele_nav_bell"
            app:tint="@color/tele_text_gray" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Notification"
            android:textSize="12sp"
            android:textColor="@color/tele_text_gray" />
    </LinearLayout>

    <!-- Plus -->
    <LinearLayout
        android:id="@+id/navTelePlus"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/tele_plus_circle">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_tele_plus"
                app:tint="@color/tele_white" />
        </FrameLayout>
    </LinearLayout>

    <!-- Schedule -->
    <LinearLayout
        android:id="@+id/navTeleSchedule"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_tele_nav_schedule"
            app:tint="@color/tele_text_gray" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Schedule"
            android:textSize="12sp"
            android:textColor="@color/tele_text_gray" />
    </LinearLayout>

    <!-- Profile -->
    <LinearLayout
        android:id="@+id/navTeleProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_tele_nav_profile"
            app:tint="@color/tele_text_gray" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Profile"
            android:textSize="12sp"
            android:textColor="@color/tele_text_gray" />
    </LinearLayout>

</LinearLayout>
