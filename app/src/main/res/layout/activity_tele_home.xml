<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootTeleHome"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/teleHomeToolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/tele_green"
        android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
        app:title="Home"
        app:titleCentered="true"
        app:titleTextColor="@color/tele_white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/teleHomeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/teleHomeToolbar"
        app:layout_constraintBottom_toTopOf="@id/btnTeleRequest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <Button
                android:id="@+id/btnTeleVeryUrgent"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/tele_btn_outline_green"
                android:text="VERY URGENT"
                android:textAllCaps="false"
                android:textColor="@color/tele_green"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Name"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <EditText
                android:id="@+id/etTeleName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/tele_bg_input_outline"
                android:hint="Your Name"
                android:textColor="@android:color/black"
                android:textColorHint="@color/tele_text_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Desease"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <EditText
                android:id="@+id/etTeleDesease"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/tele_bg_input_outline"
                android:hint="What is your illness"
                android:textColor="@android:color/black"
                android:textColorHint="@color/tele_text_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Location"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <EditText
                android:id="@+id/etTeleLocation"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/tele_bg_input_outline"
                android:hint="Where your location"
                android:textColor="@android:color/black"
                android:textColorHint="@color/tele_text_gray" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Decription ( Optional)"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <EditText
                android:id="@+id/etTeleDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/tele_bg_input_outline"
                android:gravity="top|start"
                android:hint="Describe Here"
                android:inputType="textMultiLine"
                android:textColor="@android:color/black"
                android:textColorHint="@color/tele_text_gray" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnTeleRequest"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/tele_btn_green_pill"
        android:text="Request"
        android:textAllCaps="false"
        android:textColor="@color/tele_white"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toTopOf="@id/includeTeleBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/includeTeleBottomNav"
        layout="@layout/tele_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
