<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Comic-panel grid icon.
        Layout (safe zone 20-88):
          ┌─────────────┬────────┐
          │     A       │   B    │  row: 24–55
          ├──────┬──────┴────────┤
          │  C   │      D        │  row: 59–84
          └──────┴───────────────┘
    -->

    <!-- Panel fills -->
    <path android:fillColor="#1A2A3A" android:pathData="M24,24 H59 V55 H24 Z"/>
    <path android:fillColor="#111E2C" android:pathData="M63,24 H84 V55 H63 Z"/>
    <path android:fillColor="#111E2C" android:pathData="M24,59 H43 V84 H24 Z"/>
    <path android:fillColor="#1A2A3A" android:pathData="M47,59 H84 V84 H47 Z"/>

    <!-- Panel A: bold green "C" lettermark -->
    <!-- Arc from upper-right gap to lower-right gap, counterclockwise (large arc) -->
    <path
        android:fillColor="#00D47B"
        android:pathData="M49.93,32.43 A11,11,0,1,0,49.93,46.57 L45.71,43.04 A5.5,5.5,0,1,0,45.71,35.96 Z"/>

    <!-- Panel B: target/viewfinder circle — outer green, inner dark -->
    <path
        android:fillColor="#00D47B"
        android:pathData="M66.5,39.5 A7,7,0,1,1,80.5,39.5 A7,7,0,1,1,66.5,39.5 Z"/>
    <path
        android:fillColor="#111E2C"
        android:pathData="M70.5,39.5 A3,3,0,1,1,76.5,39.5 A3,3,0,1,1,70.5,39.5 Z"/>

    <!-- Panel C: lightning bolt -->
    <path
        android:fillColor="#00D47B"
        android:pathData="M36,60 L29,71 L33,71 L27,83 L34,72 L30,72 Z"/>

    <!-- Panel D: three diagonal speed lines (upper-left to lower-right) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#00D47B"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M52,83 L67,60 M61,83 L76,60 M70,83 L82,64"/>

    <!-- White panel borders on top of all content -->
    <!-- Outer frame as 4dp ring via even-odd fill -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M20,20 H88 V88 H20 Z M24,24 H84 V84 H24 Z"/>
    <!-- Horizontal divider between rows -->
    <path android:fillColor="#FFFFFF" android:pathData="M24,55 H84 V59 H24 Z"/>
    <!-- Vertical divider in top row (between A and B) -->
    <path android:fillColor="#FFFFFF" android:pathData="M59,24 H63 V55 H59 Z"/>
    <!-- Vertical divider in bottom row (between C and D) -->
    <path android:fillColor="#FFFFFF" android:pathData="M43,59 H47 V84 H43 Z"/>

</vector>
