<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Minimal XML theme for a pure Compose app.
        Material3 colors are defined in ComixaTheme (core:ui), not here.
        This theme only sets the window background to avoid a white flash on launch.
    -->
    <style name="Theme.Comixa" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/md_bg</item>
    </style>
</resources>
